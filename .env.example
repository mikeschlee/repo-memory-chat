# Copy this file to .env and fill in your values

# LLM routing — new pipeline uses OpenRouter for all generation models.
OPENROUTER_API_KEY=your_openrouter_key_here

# Embeddings — Voyage AI voyage-3 (1024d).
VOYAGE_API_KEY=your_voyage_key_here

# Local DuckDB file (single source of truth for the rebuild).
DB_PATH=./ltm_expert.duckdb

# Legacy v0 values (still read by the old top-level db.py / memory.py until Agents B/C remove them).
ANTHROPIC_API_KEY=your_api_key_here
DATABASE_URL=postgresql://postgres:your_password@db.your_ref.supabase.co:5432/postgres
